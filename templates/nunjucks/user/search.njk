{% extends "base.njk" %}
{% block data_page %}searchusers{% endblock %}

{% block stylesheets %}
{{ super() }}
<link rel="stylesheet" href="/_frontend/vendor/tabulator/tabulator.min.css">
<link rel="stylesheet" href="/_frontend/css/tabulator_oc.css">
<style>
    .oc-filter-bar { background: var(--oc-bg-surface); padding: 1rem 1.25rem; border-radius: 0.5rem; margin-bottom: 1rem; }
</style>
{% endblock %}

{% block page_content %}
<div class="container-fluid px-0" id="userSearchContainer" data-is-support="0">
    <h4 class="mb-3">Search users</h4>
    <div class="oc-filter-bar">
        <form id="searchForm">
            <div class="row g-2 align-items-end">
                <div class="col-12 col-md-6">
                    <label class="form-label mb-1">Username</label>
                    <input type="text" id="fq" class="form-control" placeholder="e.g. username" autocomplete="off">
                </div>
                <div class="col-auto ms-md-auto">
                    <button type="submit" class="btn btn-primary">Search</button>
                </div>
            </div>
        </form>
    </div>
    <div id="statusBar" class="text-secondary small mb-1" style="min-height:1.4em;"></div>
    <div id="searchResults"></div>
</div>
{% endblock %}
