<!DOCTYPE html>
<html lang="en">
<head>
    <script>
        (function() {
            var stored = localStorage.getItem('oc-theme');
            var systemDark = window.matchMedia && window.matchMedia('(prefers-color-scheme: dark)').matches;
            var theme = stored || (systemDark ? 'dark' : 'light');
            document.documentElement.setAttribute('data-theme', theme);
        })();
    </script>
    {% block head %}
        <meta charset="utf-8">
        <meta http-equiv="X-UA-Compatible" content="IE=edge">
        <meta name="viewport" content="width=device-width, initial-scale=1">
    {% endblock %}

    <title>{% block title %}Geocaching mit Opencaching.de{% endblock %}</title>

    <link rel="stylesheet" href="/_frontend/vendor/bootstrap/bootstrap.min.css">
    <link rel="stylesheet" href="/_frontend/css/oc-style.css">

    {% block stylesheets %}
    <style>
        * { box-sizing: border-box; }
        body {
            display: grid;
            grid-template-rows: auto 1fr auto;
            min-height: 100vh;
            font-family: sans-serif;
        }
        .content {
            background-color: var(--oc-bg-body);
            color: var(--oc-text-primary);
            padding: 0;
        }
        .footer {
            background-color: var(--oc-bg-navbar);
            color: var(--oc-text-inverse);
            padding: 20px;
            text-align: center;
        }
        .footer a { color: var(--oc-footer-link-color); }
    </style>
    {% endblock %}
    <script>window.OCI18n = {{ i18n_json | safe }};</script>
    {% block i18n %}{% endblock %}
</head>

<body data-page="{% block data_page %}{% endblock %}" data-map-js="{% block data_map_js %}{% endblock %}" {% block body_start %}{% endblock %}>
{% block after_body_start %}{% endblock %}

    <header class="header">
        <nav class="navbar navbar-expand-lg navbar-dark w-100" style="background-color: var(--oc-bg-navbar);">
            <div class="container-fluid">
                <a class="navbar-brand p-0" href="/"><img src="/_frontend/images/oclogo.png" alt="Opencaching.de" height="40" style="display:block;"></a>
                <button class="navbar-toggler" type="button" data-bs-toggle="collapse" data-bs-target="#navbarNav" aria-controls="navbarNav" aria-expanded="false" aria-label="Toggle navigation">
                    <span class="navbar-toggler-icon"></span>
                </button>
                <div class="collapse navbar-collapse" id="navbarNav">
                    {% block navbar_nav %}
                        {% if user %}
                            <ul class="navbar-nav">
                                <li class="nav-item"><a class="nav-link" href="/livemap" data-i18n="Live Map">Livemap</a></li>
                                <li class="nav-item dropdown">
                                    <a class="nav-link dropdown-toggle" href="#" data-bs-toggle="dropdown" data-i18n="Caches">Caches</a>
                                    <ul class="dropdown-menu">
                                        <li><a class="dropdown-item" href="/caches" data-i18n="Search caches">Search</a></li>
                                        <li><a class="dropdown-item" href="/cache/new" data-i18n="Hide a cache">Hide</a></li>
                                    </ul>
                                </li>
                                <li class="nav-item"><a class="nav-link" href="/user" data-i18n="Users">Users</a></li>
                            </ul>
                        {% endif %}
                    {% endblock %}

                    <ul class="navbar-nav ms-auto align-items-center">
                        <li class="nav-item dropdown me-2">
                            <a class="nav-link dropdown-toggle" href="#" id="localeDropdown" data-bs-toggle="dropdown" aria-haspopup="true" aria-expanded="false">
                                <i class="fas fa-globe"></i>
                                {{ locale | upper | default('EN') }}
                            </a>
                            <ul class="dropdown-menu dropdown-menu-end" aria-labelledby="localeDropdown">
                                <li><a class="dropdown-item {% if locale == 'de' %}active{% endif %}" href="/set-locale/de">Deutsch</a></li>
                                <li><a class="dropdown-item {% if locale == 'en' %}active{% endif %}" href="/set-locale/en">English</a></li>
                            </ul>
                        </li>
                        <li class="nav-item">
                            <button class="theme-toggle" id="themeToggle" title="Toggle theme" aria-label="Toggle theme">
                                <span class="theme-icon-light">&#9788;</span>
                                <span class="theme-icon-dark">&#9789;</span>
                            </button>
                        </li>
                        {% if user %}
                            <li class="nav-item dropdown ms-2">
                                <a class="nav-link dropdown-toggle" href="#" id="userDropdown" data-bs-toggle="dropdown" aria-haspopup="true" aria-expanded="false">
                                    <i class="fas fa-user"></i>
                                    {{ user.username }}
                                </a>
                                <ul class="dropdown-menu dropdown-menu-end" aria-labelledby="userDropdown">
                                    <li><a class="dropdown-item" href="/user/profile/{{ user.id }}">Profile</a></li>
                                    <li><hr class="dropdown-divider"></li>
                                    <li><a class="dropdown-item" href="/logout">Logout</a></li>
                                </ul>
                            </li>
                        {% else %}
                            <li class="nav-item ms-2">
                                <a class="nav-link" href="/login">Login</a>
                            </li>
                        {% endif %}
                    </ul>
                </div>
            </div>
        </nav>
    </header>

    {% block page_content_before %}{% endblock %}
    <main class="content">
        {% block page_title %}{% endblock %}
        <small>{% block page_subtitle %}{% endblock %}</small>

        {% block page_content_start %}{% endblock %}
        {% block page_content %}{% endblock %}
        {% block page_content_end %}{% endblock %}
    </main>
    {% block page_content_after %}{% endblock %}

    {% block footer %}
        <footer class="footer">
            <a href="#">Privacy policy</a>, <a href="#">Imprint</a>, <a href="#">Contact</a>,
            &#xA9; opencaching.de 2026
        </footer>
    {% endblock %}

    <script src="/_frontend/vendor/bootstrap/bootstrap.bundle.min.js"></script>
    <script type="module" src="/_frontend/js/loader.js"></script>
    <script>
        // Apply translations after page load
        document.addEventListener('DOMContentLoaded', () => {
            document.querySelectorAll('[data-i18n]').forEach(el => {
                const key = el.dataset.i18n;
                if (window.OCI18n && window.OCI18n[key]) {
                    el.textContent = window.OCI18n[key];
                }
            });
        });
        // Hover dropdowns — use Bootstrap 5 data attributes
        document.querySelectorAll('.dropdown').forEach(d => {
            d.addEventListener('mouseenter', () => {
                const menu = d.querySelector('.dropdown-menu');
                if (menu) menu.classList.add('show');
                d.querySelector('.dropdown-toggle')?.classList.add('show');
                d.querySelector('.dropdown-toggle')?.setAttribute('aria-expanded', 'true');
            });
            d.addEventListener('mouseleave', () => {
                const menu = d.querySelector('.dropdown-menu');
                if (menu) menu.classList.remove('show');
                d.querySelector('.dropdown-toggle')?.classList.remove('show');
                d.querySelector('.dropdown-toggle')?.setAttribute('aria-expanded', 'false');
            });
        });
    </script>
    <script>
        (function() {
            const btn = document.getElementById('themeToggle');
            if (!btn) return;
            btn.addEventListener('click', function() {
                var current = document.documentElement.getAttribute('data-theme') || 'light';
                var next = current === 'dark' ? 'light' : 'dark';
                document.documentElement.setAttribute('data-theme', next);
                localStorage.setItem('oc-theme', next);
            });
        })();
    </script>
</body>
</html>
