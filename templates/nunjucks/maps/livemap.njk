{% extends "base.njk" %}
{% block title %}Livemap - Opencaching.de{% endblock %}
{% block data_page %}livemap{% endblock %}
{% block data_map_js %}true{% endblock %}
{% block body_start %}{% endblock %}
{% block stylesheets %}
    {{ super() }}
    <link rel="stylesheet" href="/_frontend/css/map.css">
    <style>
        body { overflow: hidden; height: 100vh; }
        main.content { padding: 0 !important; margin: 0 !important; overflow: hidden; min-height: 0; }
        #mapRoot { width: 100%; height: calc(100vh - var(--oc-navbar-height)); margin: 0; padding: 0; border: none; }
        footer { display: none !important; }
    </style>
{% endblock %}
{% block after_body_start %}
<script>
    window.uniCacheWP = [];
    (function() {
        var p = new URLSearchParams(location.search);
        window.lat         = p.has('lat')  ? parseFloat(p.get('lat'))  : 52.376;
        window.lon         = p.has('lon')  ? parseFloat(p.get('lon'))  : 9.732;
        window.defaultZoom = p.has('zoom') ? parseInt(p.get('zoom'))   : 13;
    })();
</script>
{% endblock %}
{% block page_content %}
<div id="mapRoot"></div>
{% endblock %}
